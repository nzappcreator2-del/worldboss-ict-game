{
  "name": "nextgen-play-firebase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "migrate": "node scripts/import-firestore.mjs",
    "backup": "node scripts/export-firestore.mjs",
    "backfill:directory": "node scripts/backfill-directory.mjs",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --config ../firebase.json --only firestore --project nextgen-play-rules-test \"vitest run --config vitest.rules.config.ts\"",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "preflight": "node scripts/deploy-preflight.mjs",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify": "npm run lint && npm run typecheck && npm test && npm run audit:prod && npm run build && npm run verify:dist"
  },
  "dependencies": {
    "firebase": "^12.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "firebase-admin": "^13.4.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4"
  }
}
